# OBDAI configuration — copy this file to ".env" and fill in your own keys.
#
#   cp .env.example .env
#
# ".env" is gitignored and must NEVER be committed. Do not paste real keys here.

# --- AI provider keys (you pick Claude or OpenAI at startup) ---
# At least one is required. Claude is the default.

# Anthropic / Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (optional) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- optional tuning ---
# OpenAI model to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Extra folders CarChat's /pic scans for the newest photo, colon-separated.
# Defaults already include ~/Dropbox/Camera Uploads, ~/Pictures, ~/Downloads, ./photos
# OBD_PHOTO_DIRS=/path/to/photos:/another/folder
